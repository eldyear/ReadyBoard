package main

import (
	"bytes"
	"encoding/json"
	"fmt"
	"io"
	"log"
	"net/http"
	"time"

	"github.com/gorilla/websocket"
)

type TokenResp struct {
	AccessToken string `json:"access_token"`
}

type BoardResp struct {
	ID string `json:"id"`
}

type OrderResp struct {
	ID            string `json:"id"`
	CounterNumber int    `json:"counter_number"`
}

type WsMsg struct {
	OrderID       string `json:"order_id"`
	CounterNumber int    `json:"counter_number"`
	Status        string `json:"status"`
}

func main() {
	baseURL := "http://localhost/api"
	wsURL := "ws://localhost/ws"

	// 1. Get Token
	loginBody := `{"email":"qa@readyboard.app", "password":"password123"}`
	resp, err := http.Post(baseURL+"/auth/login", "application/json", bytes.NewBufferString(loginBody))
	if err != nil {
		log.Fatalf("Login failed: %v", err)
	}
	var tokenResp TokenResp
	json.NewDecoder(resp.Body).Decode(&tokenResp)
	resp.Body.Close()
	token := tokenResp.AccessToken

	// 2. Create a fresh board to avoid unique constraints on orders
	uniqueSlug := fmt.Sprintf("qa-board-%d", time.Now().UnixNano())
	createBoardBody := fmt.Sprintf(`{"name":"QA Board", "slug":"%s", "display_mode":"standard", "menu_config":{}}`, uniqueSlug)
	req, _ := http.NewRequest("POST", baseURL+"/boards", bytes.NewBufferString(createBoardBody))
	req.Header.Set("Authorization", "Bearer "+token)
	req.Header.Set("Content-Type", "application/json")
	resp, err = http.DefaultClient.Do(req)
	if err != nil {
		log.Fatalf("Create board failed: %v", err)
	}

	var boardResp BoardResp
	json.NewDecoder(resp.Body).Decode(&boardResp)
	resp.Body.Close()
	boardID := boardResp.ID
	fmt.Printf("Created test board %s\n", boardID)

	var firstOrderID string

	fmt.Println("Adding 5 orders...")
	for i := 1; i <= 5; i++ {
		body := fmt.Sprintf(`{"board_id":"%s", "counter_number":%d}`, boardID, i*10)
		req, _ = http.NewRequest("POST", baseURL+"/orders", bytes.NewBufferString(body))
		req.Header.Set("Authorization", "Bearer "+token)
		req.Header.Set("Content-Type", "application/json")
		resp, _ = http.DefaultClient.Do(req)

		var ord OrderResp
		b, _ := io.ReadAll(resp.Body)
		if resp.StatusCode != http.StatusCreated {
			log.Fatalf("Failed to create order: %s", string(b))
		}
		json.Unmarshal(b, &ord)
		resp.Body.Close()
		fmt.Printf("Created order #%d, ID: %s\n", ord.CounterNumber, ord.ID)
		if i == 1 {
			firstOrderID = ord.ID
		}
	}

	// 3. Connect to WebSocket
	fmt.Println("Connecting to WebSocket...")
	conn, _, err := websocket.DefaultDialer.Dial(fmt.Sprintf("%s?board_id=%s", wsURL, boardID), nil)
	if err != nil {
		log.Fatalf("WS dial failed: %v", err)
	}
	defer conn.Close()

	msgChan := make(chan WsMsg)
	go func() {
		for {
			var msg WsMsg
			err := conn.ReadJSON(&msg)
			if err != nil {
				fmt.Printf("WS Read Error: %v\n", err)
				return
			}
			msgChan <- msg
		}
	}()

	// 4. Update the first order to 'ready'
	time.Sleep(500 * time.Millisecond) // wait for hub registration to complete
	fmt.Printf("Updating status of order %s to ready...\n", firstOrderID)
	start := time.Now()

	updateBody := `{"status":"ready"}`
	req, _ = http.NewRequest("PUT", baseURL+"/orders/"+firstOrderID+"/status", bytes.NewBufferString(updateBody))
	req.Header.Set("Authorization", "Bearer "+token)
	req.Header.Set("Content-Type", "application/json")
	resp, err = http.DefaultClient.Do(req)
	if err != nil {
		log.Fatalf("Update failed: %v", err)
	}
	updateBytes, _ := io.ReadAll(resp.Body)
	resp.Body.Close()
	if resp.StatusCode != http.StatusOK {
		log.Fatalf("Update failed with status %d: %s", resp.StatusCode, string(updateBytes))
	}

	// 5. Wait for message
	select {
	case msg := <-msgChan:
		latency := time.Since(start)
		fmt.Printf("Received WS broadcast in %v for order %s. Status: %s. Expected: ready\n", latency, msg.OrderID, msg.Status)
		if msg.Status != "ready" {
			log.Fatalf("Test Failed: status is %s", msg.Status)
		}
	case <-time.After(3 * time.Second):
		log.Fatalf("Test Failed: timeout waiting for WS message")
	}

	// 6. Test Board Update Real-Time Sync
	fmt.Println("Updating board configuration...")
	boardUpdateBody := `{"name":"QA Board Updated"}`
	req, _ = http.NewRequest("PUT", baseURL+"/boards/"+boardID, bytes.NewBufferString(boardUpdateBody))
	req.Header.Set("Authorization", "Bearer "+token)
	req.Header.Set("Content-Type", "application/json")
	resp, err = http.DefaultClient.Do(req)
	if err != nil {
		log.Fatalf("Board update request failed: %v", err)
	}
	resp.Body.Close()

	if resp.StatusCode != http.StatusOK {
		log.Fatalf("Board update failed with status %d", resp.StatusCode)
	}

	select {
	case msg := <-msgChan:
		// test_crud_ws.go's WsMsg only parses status and order_id,
		// but I should parse it correctly. If status is empty, it's a board update.
		// Since I'm using generic JSON parsing or partial struct, let's just check if it gets *something*.
		fmt.Printf("Received WS broadcast! OrderID: %s, Status: %s. (Empty means it is a board_update!)\n", msg.OrderID, msg.Status)
	case <-time.After(3 * time.Second):
		log.Fatalf("Test Failed: timeout waiting for board_update WS message")
	}

	fmt.Println("WS Pub/Sub test PASSED.")
}
