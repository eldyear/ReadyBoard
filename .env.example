# ─────────────────────────────────────────────
# ReadyBoard – Environment Variables
# Copy to .env and fill in real values
# NEVER commit .env to version control
# ─────────────────────────────────────────────

# Environment
ENV=development   # production | development

# PostgreSQL
POSTGRES_USER=readyboard
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=readyboard

# Redis
REDIS_PASSWORD=change_me_redis_password

# JWT
JWT_SECRET=change_me_at_least_32_chars_long_secret
JWT_REFRESH_SECRET=change_me_different_32_chars_refresh_secret

# Optional: Override internal service ports
# PORT_API=8080
# PORT_WS=8081
